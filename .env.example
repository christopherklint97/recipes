# SQLite database file path. In container = /data/recipes.db.
DATABASE_URL="dev.db"

# Login credentials. Hash is generated by `bun run hash-password <password>`.
AUTH_USERNAME="you"
AUTH_PASSWORD_HASH="scrypt$<salt>$<hash>"

# 32+ random chars; signs the session cookie. Generate with:
#   openssl rand -base64 48
AUTH_SECRET=""
